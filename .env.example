# Copy to .env (gitignored). Loaded automatically by `npm start`.
# Shell/CI environment variables always win over this file.
# Everything is optional — defaults work out of the box.

# ── Common (what most people actually set) ───────────────────

# Shared HTTP(S) proxy for ALL CLI children (Codex / OpenCode / Grok / …).
# INVOKE_CLI_PROXY=http://127.0.0.1:7892

# Isolate Codex CLI cache from the Codex desktop app (~/.codex).
# INVOKE_CODEX_HOME=C:\Users\you\.codex-cli

# Grok API key for headless auth (or run `grok login` instead).
# XAI_API_KEY=

# HTTP listen port (default: 8787)
# PORT=8787

# ── Occasional ───────────────────────────────────────────────

# Grok-only proxy override (only if different from INVOKE_CLI_PROXY).
# GROK_PROXY=http://127.0.0.1:7892

# Windows: preferred PowerShell 7 path for provider tool shells.
# SHIFT_PWSH_PATH=C:\Program Files\PowerShell\7\pwsh.exe

# Storage: files | dual (default) | sqlite
# SHIFT_STORAGE_MODE=dual
