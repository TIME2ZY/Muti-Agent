# Copy to .env (or .env.local) and edit. Both are gitignored.
# `npm start` and standalone invoke-cli auto-load these files from the project
# root. Existing shell/CI environment variables always win over file values.
# All variables are optional unless noted.

# ── Server / UI ──────────────────────────────────────────────
# HTTP listen port (default: 8787)
PORT=8787

# Stable UI token for X-Shift-UI-Token. If unset, a random token is
# generated per process and injected into index.html.
# SHIFT_UI_TOKEN=

# Base URL used by the cross-platform callback client (default: request host)
# SHIFT_API_URL=http://127.0.0.1:8787

# Callback token TTL in milliseconds
# SHIFT_TOKEN_TTL_MS=

# Transcript root directory (default: data/runtime/transcripts)
# SHIFT_TRANSCRIPT_DIR=

# Storage transition mode: dual mirrors new writes to SQLite while files remain
# the read source. Use files to disable the SQLite mirror.
# Storage: files (legacy), dual (file reads + SQLite mirror), sqlite (SQLite primary reads + file fallback)
# SHIFT_STORAGE_MODE=dual

# SQLite memory database path (default: data/runtime/memory.sqlite)
# SHIFT_MEMORY_DB=

# Test-only: override context capacity checks
# SHIFT_TEST_CAPACITY=

# Set by preview child processes; do not set manually for the main server
# SHIFT_PREVIEW=1

# Max Agent-to-Agent @mention hop depth (default: 15)
# MAX_A2A_DEPTH=15

# ── CLI invoke (usually injected by the server per run) ──────
# SHIFT_THREAD_ID=
# SHIFT_INVOCATION_ID=
# SHIFT_CALLBACK_TOKEN=
# SHIFT_WORKTREE=0
# SHIFT_BASE_DIR=
# SHIFT_WORKTREE_DIR=
# SHIFT_BRANCH=
# INVOKE_SESSION_ID=
# INVOKE_SESSION_FILE=
# INVOKE_WORKSPACE_KEY=

# ── Optional CLI knobs ───────────────────────────────────────
# Windows only: preferred PowerShell 7 executable for provider tool shells.
# If unset, Shift looks for pwsh.exe on PATH and keeps callback HTTP calls in Node.
# SHIFT_PWSH_PATH=C:\Program Files\PowerShell\7\pwsh.exe

# Shared HTTP(S) proxy for ALL CLI children (Codex / OpenCode / Grok / …).
# Prefer this over GROK_PROXY when every provider should use the same proxy.
# INVOKE_CLI_PROXY=http://127.0.0.1:7892
#
# Optional Grok-only override (only if Grok needs a different proxy than the
# rest). Aliases: INVOKE_GROK_PROXY, GROK_HTTP_PROXY, GROK_HTTPS_PROXY
# GROK_PROXY=http://127.0.0.1:7892

# Log raw CLI events when 1|true|yes|on
# INVOKE_RAW_EVENT_LOG=

# Log resolved CLI proxy details at startup and before invocation (default: off)
# INVOKE_CLI_PROXY_LOG=

# Codex-only home directory. Mapped to CODEX_HOME for the Codex CLI child only,
# so CLI sessions/cache stay isolated from the Codex desktop app (~/.codex).
# INVOKE_CODEX_HOME=C:\Users\you\.codex-cli


# Log Agent-to-Agent handoff metrics to the terminal (default: off).
# Metrics are still delivered to the UI over SSE when this is unset.
# SHIFT_HANDOFF_METRICS_LOG=

# ── Grok Build CLI (provider name: grok, model: grok-4.5) ────
# Install local CLI (same idea as codex / opencode):
#   macOS/Linux: curl -fsSL https://x.ai/cli/install.sh | bash
#   Windows:     irm https://x.ai/cli/install.ps1 | iex
# Then: grok login   OR set an API key for headless auth:
# XAI_API_KEY=
# Create a key at https://console.x.ai/ if you prefer key auth.
