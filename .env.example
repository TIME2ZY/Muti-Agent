# Copy to .env (optional). The server reads process.env; loading .env is up to
# your shell / process manager (this app does not bundle dotenv).
# All variables are optional unless noted.

# ── Server / UI ──────────────────────────────────────────────
# HTTP listen port (default: 8787)
PORT=8787

# Stable UI token for X-Cat-Cafe-UI-Token. If unset, a random token is
# generated per process and injected into index.html.
# CAT_CAFE_UI_TOKEN=

# Base URL agents use in callback curl examples (default: request host)
# CAT_CAFE_API_URL=http://127.0.0.1:8787

# Callback token TTL in milliseconds
# CAT_CAFE_TOKEN_TTL_MS=

# Transcript root directory (default: data/runtime/transcripts)
# CAT_CAFE_TRANSCRIPT_DIR=

# Test-only: override context capacity checks
# CAT_CAFE_TEST_CAPACITY=

# Set by preview child processes; do not set manually for the main server
# CAT_CAFE_PREVIEW=1

# Max Agent-to-Agent @mention hop depth (default: 15)
# MAX_A2A_DEPTH=15

# ── CLI invoke (usually injected by the server per run) ──────
# CAT_CAFE_THREAD_ID=
# CAT_CAFE_INVOCATION_ID=
# CAT_CAFE_CALLBACK_TOKEN=
# CAT_CAFE_WORKTREE=0
# CAT_CAFE_BASE_DIR=
# CAT_CAFE_WORKTREE_DIR=
# CAT_CAFE_BRANCH=
# INVOKE_SESSION_ID=
# INVOKE_SESSION_FILE=
# INVOKE_WORKSPACE_KEY=

# ── Optional CLI knobs ───────────────────────────────────────
# HTTP(S) proxy for invoke-cli
# INVOKE_CLI_PROXY=

# Log raw CLI events when 1|true|yes|on
# INVOKE_RAW_EVENT_LOG=
