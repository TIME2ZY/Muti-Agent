{
  "name": "shift-console",
  "version": "0.1.0",
  "description": "Shift — local multi-agent console (交班台)",
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/server/index.js",
    "test": "node scripts/run-tests.js",
    "check": "node scripts/check-syntax.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "vendor:md": "node scripts/vendor-md.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "prettier": "^3.6.2"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "dompurify": "^3.4.12",
    "isomorphic-dompurify": "^3.19.0",
    "markdown-it": "^14.3.0",
    "markdown-it-multimd-table": "^4.2.3",
    "markdown-it-task-lists": "^2.1.1"
  }
}
